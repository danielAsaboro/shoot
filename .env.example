# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user@localhost:5432/shoot?schema=public

# ─── Privy Auth ──────────────────────────────────────────────────────────────
# Get credentials at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
NEXT_PUBLIC_PRIVY_APP_SECRET=your_privy_app_secret

# ─── Competition ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_COMPETITION_PROVIDER=adrena

# ─── Adrena APIs ─────────────────────────────────────────────────────────────
# Data API (public, no key required)
ADRENA_DATA_API_BASE_URL=https://datapi.adrena.trade

# Competition Service (primary source in production)
ADRENA_COMPETITION_API_BASE_URL=https://adrena-competition-service.onrender.com

# WebSocket auth
ADRENA_API_KEY=your_adrena_api_key
ADRENA_WS_HOST=adrena-competition-service.onrender.com

# ─── Solana ──────────────────────────────────────────────────────────────────
# Cluster: localnet | devnet | mainnet
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# Optional: override the default RPC URL for the selected cluster
# NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_AUTHORITY=your_program_authority_pubkey
# Keypair for ADX buyback wallet (JSON array of secret key bytes)
# Required for Jupiter V6 USDC→ADX swap on cohort settlement
BUYBACK_WALLET_KEYPAIR=[0,1,2,...]

# ─── Notifications ───────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_OPS_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Automation ──────────────────────────────────────────────────────────────
# Bearer token to authenticate /api/cron/* endpoints
CRON_SECRET=your_cron_secret
# Bearer token to authenticate /api/admin/* endpoints
ADMIN_SECRET=your_admin_secret
